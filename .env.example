# Supabase — Project Settings → API
# Dashboard: https://supabase.com/dashboard/project/rsaoiobpvszinripuocc/settings/api
VITE_SUPABASE_URL=https://rsaoiobpvszinripuocc.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin login — optional fallback if DB admin migration not run yet
# VITE_ADMIN_PASSWORD=your-secure-password-here

# Optional: run `npm run setup:admin` instead of pasting SQL manually
# Supabase → Project Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# AI chatbot — free tier at https://aistudio.google.com/apikey
# Server-only: do NOT prefix with VITE_ (keeps key off the client bundle)
GEMINI_API_KEY=your-gemini-api-key-here
